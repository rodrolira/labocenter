# ─────────────────────────── Backend (apps/api) ───────────────────────────
NODE_ENV=development
API_PORT=3000

# PostgreSQL (coincide con docker/docker-compose.yml: host 5433 → contenedor 5432)
DATABASE_URL=postgresql://labocenter:labocenter@localhost:5433/labocenter?schema=public

# Autenticación (ver docs/07-autenticacion.md) — usar secretos fuertes en producción
JWT_SECRET=cambia-esto-por-un-secreto-fuerte-de-al-menos-32-chars
JWT_ACCESS_TTL=15m
REFRESH_TTL=30d

# CORS: origen del frontend en desarrollo
CORS_ORIGIN=http://localhost:5173

# Correo (Fase 7) — SMTP
SMTP_URL=

# ─────────────────────────── Frontend (apps/web) ──────────────────────────
VITE_API_URL=http://localhost:3000/api/v1
