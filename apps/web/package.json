  "dependencies": {
    "@labocenter/contracts": "workspace:*",
    "@labocenter/ui": "workspace:*",
    "@react-router/node": "^7.1.1",
    "@react-router/serve": "^7.1.1",
    "isbot": "^5.1.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1"
  },
  "devDependencies": {
    "@labocenter/config": "workspace:*",
    "@react-router/dev": "^7.1.1",
    "@tailwindcss/vite": "^4.0.0",
    "eslint": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
