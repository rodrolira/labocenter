{
  "name": "@labocenter/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend de Labocenter (React 19 + Vite + React Router framework mode, SSR)",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
